# Client-side NXGS environment. These values are safe to ship to the client.
NXGS_SUPABASE_URL=https://your-project-ref.supabase.co
NXGS_SUPABASE_ANON_KEY=your-supabase-anon-key
NXGS_RAZORPAY_KEY_ID=rzp_live_or_test_key_id

# Testing only. When enabled together with app_settings.test_payment_bypass=true
# on the backend, selecting a time plan creates the session without Razorpay.
NXGS_TEST_PAYMENT_BYPASS=0

# Optional. Defaults to $NXGS_SUPABASE_URL/functions/v1.
NXGS_RENTAL_FUNCTION_BASE_URL=https://your-project-ref.supabase.co/functions/v1

# Supabase Edge Function secrets. Do not put these in the client environment.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Optional. If omitted, controller admin tokens are signed with SUPABASE_SERVICE_ROLE_KEY.
CONTROLLER_ADMIN_TOKEN_SECRET=replace-with-random-server-secret
